# OmniSignal Risk Radar — example environment configuration.
# Copy to ".env" and fill in values ONLY if you intend to test real connectors.
# Never commit your real .env file. Synthetic demo mode works without any of the
# real-connector values below.

# ---------------------------------------------------------------------------
# Core mode flags
# ---------------------------------------------------------------------------
# Seeds and serves the synthetic demo dataset. Keep true for the default demo.
DEMO_MODE=true

# Master switch for real Gmail/Calendar connectors. Must be true BEFORE any real
# OAuth route or real sync will run. When false, all real connector endpoints
# return a safe "disabled" response and the synthetic demo stays active.
REAL_CONNECTORS_ENABLED=false

# ---------------------------------------------------------------------------
# App wiring
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./backend/omnisignal.db
FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ---------------------------------------------------------------------------
# Google OAuth (read-only) — required ONLY for real Google connector testing.
# Leave blank to keep real connectors unconfigured. See docs/REAL_CONNECTOR_SETUP.md.
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Symmetric key used to encrypt OAuth tokens at rest (Fernet).
# Generate locally and NEVER commit it:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If REAL_CONNECTORS_ENABLED=true and this key is missing, real OAuth/token
# storage is blocked with a clear error (the app still starts in demo mode).
TOKEN_ENCRYPTION_KEY=
