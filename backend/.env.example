# Backend environment (copy to backend/.env). Demo mode needs none of the
# real-connector values. See the repo-root .env.example and
# docs/REAL_CONNECTOR_SETUP.md for full guidance.

DEMO_MODE=true
REAL_CONNECTORS_ENABLED=false
APPROVAL_GATED_WRITES=false
# Relative SQLite paths are resolved from the repository root.
DATABASE_URL=sqlite:///./backend/omnisignal.db
FRONTEND_ORIGIN=http://localhost:3000

# Google OAuth (read-only) — required ONLY for real Google connector testing.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# Fernet key for encrypting OAuth tokens at rest. Generate locally, never commit:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
